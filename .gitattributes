# ============================================================

# Davison Financial Model

# .gitattributes

# ============================================================

# ------------------------------------------------------------

# Automatically normalize line endings for text files

# ------------------------------------------------------------

* text=auto

# ------------------------------------------------------------

# Python

# ------------------------------------------------------------

*.py      text eol=lf
*.pyi     text eol=lf

# ------------------------------------------------------------

# Markdown

# ------------------------------------------------------------

*.md      text eol=lf

# ------------------------------------------------------------

# Configuration Files

# ------------------------------------------------------------

*.txt     text eol=lf
*.json    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.toml    text eol=lf
*.ini     text eol=lf
*.cfg     text eol=lf

# ------------------------------------------------------------

# Shell Scripts

# ------------------------------------------------------------

*.sh      text eol=lf
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# ------------------------------------------------------------

# SQL

# ------------------------------------------------------------

*.sql     text eol=lf

# ------------------------------------------------------------

# XML / HTML / CSS

# ------------------------------------------------------------

*.xml     text eol=lf
*.html    text eol=lf
*.css     text eol=lf

# ------------------------------------------------------------

# Binary Files

# ------------------------------------------------------------

*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary

*.pdf     binary

*.zip     binary
*.7z      binary
*.gz      binary
*.tar     binary

# ------------------------------------------------------------

# Microsoft Office

# ------------------------------------------------------------

*.xlsx    binary
*.xlsm    binary
*.xls     binary

*.docx    binary
*.pptx    binary

# ------------------------------------------------------------

# SQLite

# ------------------------------------------------------------

*.db      binary
*.sqlite  binary
*.sqlite3 binary

# ------------------------------------------------------------

# Fonts

# ------------------------------------------------------------

*.ttf     binary
*.otf     binary

# ------------------------------------------------------------

# Executables

# ------------------------------------------------------------

*.exe     binary
*.dll     binary
*.so      binary
*.dylib   binary

# ------------------------------------------------------------

# Git Merge Behavior

# ------------------------------------------------------------

*.md      text diff=markdown

# ------------------------------------------------------------

# End of File

# ------------------------------------------------------------
